let lookback = 30d;
let interpreters = dynamic(["powershell","pwsh","cmd","mshta","wscript","cscript","rundll32"]);
let exec_patterns = dynamic(["iex","invoke-webrequest","invoke-restmethod","downloadstring","net.webclient","-enc","encodedcommand","-w hidden","-windowstyle hidden","downloadfile","start-bitstransfer","invoke-expression","iwr","irm"]);
let hidden_switches = dynamic(["-w hidden","-w h","-windowstyle hidden","-windowstyle h"]);
let ps_download_patterns = dynamic(["iex","invoke-expression","downloadstring","invoke-webrequest","invoke-restmethod","irm","iwr","net.webclient","webclient","downloadfile","start-bitstransfer","add-type","dllimport","kernel32.dll","virtualalloc","createthread","-enc","encodedcommand"]);

let ps_hidden_download =
DeviceProcessEvents
| where TimeGenerated >= ago(lookback)
| extend cmd = tolower(ProcessCommandLine)
| extend proc = tolower(FileName)
| where proc in~ ("powershell.exe","pwsh.exe","powershell","pwsh")
    or cmd has_any (dynamic(["powershell","pwsh"]))
| where cmd has_any (hidden_switches)
| where cmd has_any (ps_download_patterns)
| extend DetectionName = "N0435_powershell_hidden_download"
| extend Severity = "High"
| extend Tactic = "Execution"
| extend Technique = "T1059.001"
| project
    TimeGenerated,
    DeviceName,
    DetectionName,
    Severity,
    Tactic,
    Technique,
    AccountName,
    InitiatingProcessAccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    SHA1,
    MD5,
    FolderPath,
    ReportId;

let runmru_exec =
DeviceRegistryEvents
| where TimeGenerated >= ago(lookback)
| where RegistryKey has @"\Software\Microsoft\Windows\CurrentVersion\Explorer\RunMRU"
| extend cmd = tolower(RegistryValueData)
| where cmd has_any (interpreters)
| where cmd has_any (exec_patterns)
| extend DetectionName = "N0435_runmru_interpreter_exec"
| extend Severity = "High"
| extend Tactic = "Execution"
| extend Technique = "T1112"
| project
    TimeGenerated,
    DeviceName,
    DetectionName,
    Severity,
    Tactic,
    Technique,
    AccountName,
    InitiatingProcessAccountName,
    RegistryKey,
    RegistryValueName,
    RegistryValueData,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    ReportId;

union isfuzzy=true ps_hidden_download, runmru_exec
| order by TimeGenerated desc

