rule N1005_LSASS_DUMP_EXFILTRATION {
  meta:
    author = "Improved by Claude"
    description = "Detects potential exfiltration of LSASS dump files over SMB or HTTP after credential dumping"
    severity = "CRITICAL"
    mitre_tactic = "Exfiltration"
    mitre_technique = "T1041"
    references = "https://attack.mitre.org/techniques/T1041/"
    version = "1.0"

  events:
    // File creation event — dump file written to disk
    $f.metadata.event_type = "FILE_CREATION"
    re.regex(
      $f.target.file.full_path,
      `(?i)(lsass.*\.dmp|lsass.*\.zip|lsass.*\.bin|credential.*\.dmp|dump.*\.dmp)`
    )

    // Network event — outbound connection shortly after dump
    $n.metadata.event_type = "NETWORK_CONNECTION"
    $n.network.direction = "OUTBOUND"

    // Correlate on same host
    $f.principal.hostname = $n.principal.hostname
    $host = $f.principal.hostname

    // Outbound over SMB (445) or common HTTP/S exfil ports
    (
      $n.target.port = 445 or
      $n.target.port = 80  or
      $n.target.port = 443 or
      $n.target.port = 8080 or
      $n.target.port = 8443
    )

    // Exclude internal RFC1918 destinations (tune to your environment)
    not re.regex(
      $n.target.ip,
      `^(10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.)`
    )

  match:
    $host over 30m

  condition:
    $f and $n
}
