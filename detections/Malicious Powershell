rule N1503_PowerShell_Hidden_Appx_VSCode_Removal {
  meta:
    author = "OpenAI"
    description = "Detects hidden PowerShell removing Microsoft Visual Studio Code AppX packages"
    severity = "Medium"
    confidence = "Medium"
    mitre_tactic = "Defense Evasion"
    mitre_technique = "T1059.001"
    rule_version = "1.0"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    $e.principal.process.file.full_path = /powershell\.exe/i
    re.regex($e.principal.process.command_line, `(?i)-w(?:indowstyle)?\s+hidden`)
    re.regex($e.principal.process.command_line, `(?i)-executionpolicy\s+bypass`)
    re.regex($e.principal.process.command_line, `(?i)(Get-AppxPackage\s+-Name\s+'?Microsoft\.VisualStudioCode'?|Remove-AppxPackage\s+-Package\s+'?Microsoft\.VisualStudioCode_)`)

  outcome:
    $risk_score = 55
    $severity = "MEDIUM"
    $confidence = "MEDIUM"
    $summary = "Hidden PowerShell queried or removed Microsoft Visual Studio Code AppX package"
    $command_line = array_distinct($e.principal.process.command_line)
    $hostname = array_distinct($e.principal.hostname)
    $user = array_distinct($e.principal.user.userid)

  condition:
    $e
}
