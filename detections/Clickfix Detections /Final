rule PT_CLICKFIX_CORRELATED_EXECUTION_CHAIN
{
  meta:
    author = "OpenAI"
    description = "Correlates RunMRU modification with suspicious Explorer-driven execution and optional outbound network activity"
    severity = "CRITICAL"
    tactic = "Execution"
    technique = "T1204.002"
    validation_type = "Purple Team"
    platform = "Windows"
    rule_version = "1.0"

  events:
    /*
      Event 1: Suspicious RunMRU registry modification
    */
    $reg.metadata.event_type = "REGISTRY_MODIFICATION"
    $reg.principal.hostname != ""
    re.regex($reg.target.registry.registry_key, `(?i)\\currentversion\\explorer\\runmru(\\|$)`)
    re.regex($reg.principal.process.file.full_path, `(?i)\\explorer\.exe$`)
    re.regex(
      $reg.target.registry.registry_value_data,
      `(?i)(powershell|pwsh|cmd|mshta|rundll32|wscript|cscript|curl|wget|invoke-webrequest|invoke-restmethod|downloadstring|downloadfile|frombase64string|-enc\b|-encodedcommand\b)`
    )

    /*
      Event 2: Suspicious process launch shortly after
    */
    $proc.metadata.event_type = "PROCESS_LAUNCH"
    $proc.principal.hostname = $reg.principal.hostname
    re.regex($proc.principal.process.file.full_path, `(?i)\\explorer\.exe$`)
    re.regex(
      $proc.target.process.file.full_path,
      `(?i)\\(powershell|pwsh|cmd|mshta|rundll32|wscript|cscript|curl|wget)\.exe$`
    )
    re.regex(
      $proc.target.process.command_line,
      `(?i)(powershell|pwsh|cmd|mshta|rundll32|wscript|cscript|curl|wget|invoke-webrequest|invoke-restmethod|downloadstring|downloadfile|frombase64string|-enc\b|-encodedcommand\b|-w\s+hidden|-windowstyle\s+hidden|javascript:|vbscript:|&&|\|\||;)`
    )

    /*
      Event 3: Optional follow-on network activity
      Keep this broad for validation purposes.
    */
    $net.metadata.event_type = "NETWORK_CONNECTION"
    $net.principal.hostname = $reg.principal.hostname

  match:
    $reg, $proc, $net over 5m

  condition:
    $reg and $proc
}
