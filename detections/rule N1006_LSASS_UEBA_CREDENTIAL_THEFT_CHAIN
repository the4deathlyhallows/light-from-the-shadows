rule N1006_LSASS_UEBA_CREDENTIAL_THEFT_CHAIN {
  meta:
    author = "Improved by Claude"
    description = "Correlates LSASS dumping with lateral movement indicators and anomalous auth behavior — high-confidence credential theft chain"
    severity = "CRITICAL"
    mitre_tactic = "Credential Access, Lateral Movement"
    mitre_technique = "T1003.001, T1550.002, T1021.002"
    references = "https://attack.mitre.org/techniques/T1003/001/"
    version = "1.0"

  events:
    // Stage 1 — Credential dumping process
    $dump.metadata.event_type = "PROCESS_LAUNCH"
    re.regex(
      $dump.principal.process.command_line,
      `(?i)(mimikatz|sekurlsa|comsvcs.*MiniDump|procdump.*lsass|Out-Minidump|Invoke-Mimikatz)`
    )

    // Stage 2 — Pass-the-Hash or Pass-the-Ticket indicator
    $auth.metadata.event_type = "USER_LOGIN"
    (
      $auth.extensions.auth.auth_details = "NTLM" or
      $auth.extensions.auth.mechanism = "KERBEROS"
    )
    $auth.metadata.event_timestamp.seconds >
      $dump.metadata.event_timestamp.seconds

    // Stage 3 — Lateral movement via SMB or WMI/PSExec
    $lateral.metadata.event_type = "NETWORK_CONNECTION"
    (
      $lateral.target.port = 445  or  // SMB
      $lateral.target.port = 135  or  // RPC/WMI
      $lateral.target.port = 5985 or  // WinRM HTTP
      $lateral.target.port = 5986     // WinRM HTTPS
    )
    $lateral.metadata.event_timestamp.seconds >
      $auth.metadata.event_timestamp.seconds

    // Correlate all stages on the same host and user
    $dump.principal.hostname = $auth.principal.hostname
    $auth.principal.hostname = $lateral.principal.hostname
    $dump.principal.user.userid = $auth.principal.user.userid

    $host = $dump.principal.hostname
    $user = $dump.principal.user.userid

    // Exclude known admin/service accounts (tune this)
    not re.regex(
      $dump.principal.user.userid,
      `(?i)(svc_|_svc|admin_approved|monitoring)`
    )

  match:
    $host, $user over 1h

  outcome:
    $risk_score = max(
      if($dump.metadata.event_type = "PROCESS_LAUNCH", 40) +
      if($auth.extensions.auth.auth_details = "NTLM", 30) +
      if($lateral.target.port = 445, 30)
    )

  condition:
    $dump and $auth and $lateral
}
