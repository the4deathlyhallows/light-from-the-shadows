rule N1004_LSASS_DUMPING_OR_CREDENTIAL_THEFT {
  meta:
    author = "Improved by Claude"
    description = "Detects possible LSASS dumping or credential theft activity via process launch events"
    severity = "CRITICAL"
    mitre_tactic = "Credential Access"
    mitre_technique = "T1003.001"
    references = "https://attack.mitre.org/techniques/T1003/001/"
    version = "2.0"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"

    (
      // Known credential dumping tools and DLLs
      re.regex(
        $e.principal.process.command_line,
        `(?i)(mimikatz|sekurlsa|lsadump|wce\.exe|pwdump|fgdump|gsecdump|cachedump)`
      )
      or

      // MiniDump via comsvcs.dll (living-off-the-land)
      re.regex(
        $e.principal.process.command_line,
        `(?i)comsvcs(\.dll)?.*MiniDump`
      )
      or

      // ProcDump targeting lsass
      re.regex(
        $e.principal.process.command_line,
        `(?i)procdump.*lsass`
      )
      or

      // rundll32 abused to dump via comsvcs
      (
        re.regex($e.principal.process.file.full_path, `(?i)rundll32\.exe`) and
        re.regex($e.principal.process.command_line, `(?i)comsvcs`)
      )
      or

      // Task Manager / direct lsass dump via legitimate binaries
      re.regex(
        $e.principal.process.command_line,
        `(?i)(lsass\.exe|lsass\.dmp)`
      )
      or

      // Suspicious PowerShell access to LSASS memory
      re.regex(
        $e.principal.process.command_line,
        `(?i)(Out-Minidump|Invoke-Mimikatz|Get-Process lsass)`
      )
    )

    // Exclude known legitimate security tools (tune to your environment)
    not re.regex(
      $e.principal.process.file.full_path,
      `(?i)(CrowdStrike|SentinelOne|CarbonBlack|Defender|cylance)`
    )

  condition:
    $e
}
