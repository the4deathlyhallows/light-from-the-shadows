rule N1502_PowerShell_ExternalDownload_InMemory_Execution {
  meta:
    author = "OpenAI"
    description = "Detects hidden PowerShell downloading content from a URL/IP and executing it via runspace or XSL transform"
    severity = "Critical"
    confidence = "High"
    mitre_tactic = "Execution, Command and Control, Defense Evasion"
    mitre_technique = "T1059.001, T1105, T1216.001"
    rule_version = "1.0"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    $e.principal.process.file.full_path = /powershell\.exe/i

    re.regex($e.principal.process.command_line, `(?i)-w(?:indowstyle)?\s+hidden`)
    re.regex($e.principal.process.command_line, `(?i)-(nop|noprofile)`)
    re.regex($e.principal.process.command_line, `(?i)(DownloadString|DownloadData)`)
    re.regex($e.principal.process.command_line, `(?i)(http|https)://([0-9]{1,3}\.){3}[0-9]{1,3}|https?://`)
    re.regex(
      $e.principal.process.command_line,
      `(?i)(runspacefactory\]::CreateRunspace|\[powershell\]::Create|AddScript|\.Invoke\(\)|Xml\.Xsl\.XslCompiledTransform|EnableScript\s*=\s*\$true)`
    )

  outcome:
    $risk_score = 95
    $severity = "CRITICAL"
    $confidence = "HIGH"
    $summary = "Hidden PowerShell downloaded remote content and executed it in-memory"
    $command_line = array_distinct($e.principal.process.command_line)
    $hostname = array_distinct($e.principal.hostname)
    $user = array_distinct($e.principal.user.userid)

  condition:
    $e
}
